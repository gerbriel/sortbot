# Copy this file to .env and fill in the values.
#
# ⚠️  SECURITY: every variable here is prefixed VITE_, which means Vite compiles it
# into the PUBLIC JavaScript bundle. Anyone who visits the deployed site can read it.
# Only ever put publishable values in this file.
#
# NEVER put a Supabase service_role key, a Shopify Admin token, or any other real
# secret in a VITE_ variable — it would be published to every visitor and would
# bypass RLS. Server-side secrets belong in Supabase Edge Function secrets instead
# (`supabase secrets set ...`). See the Security section of README.md.

# ---- Required -------------------------------------------------------------
# The app throws on load without these two.

# Your Supabase project URL.
VITE_SUPABASE_URL=https://your-project.supabase.co

# The Supabase ANON (publishable) key — NOT the service_role key.
# This one is public by design; RLS is what enforces access.
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---- Optional -------------------------------------------------------------

# Denominator for the storage usage meter, in GB. 1 = free tier, 100 = Pro.
VITE_STORAGE_LIMIT_GB=100
